					-- Rounds to nearest increment and clamps to [minVal, maxVal]
					local function roundToIncrement(val)
						val = math.clamp(val, minVal, maxVal)
						return math.floor((val - minVal) / increment + 0.5) * increment + minVal
					end

					-- Updates visuals (circle position + text) and internal value, fires callback
					local function updateSlider(inputX)
						local barPos = slider["3a"].AbsolutePosition.X
						local barSize = slider["3a"].AbsoluteSize.X

						local percent = math.clamp((inputX - barPos) / barSize, 0, 1)
						local rawVal = minVal + (percent * (maxVal - minVal))
						local newVal = roundToIncrement(rawVal)

						-- Recompute percent from the rounded value so the circle snaps to increments
						local snappedPercent = (newVal - minVal) / (maxVal - minVal)

						sliderVal = newVal
						slider["3c"].Position = UDim2.new(snappedPercent, 0, -1.33333, 0)
						slider["3e"].Text = tostring(newVal)

						if scfg["callback"] then
							scfg["callback"](sliderVal)
						end
					end

					slider["3a"].InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							dragging = true
							updateSlider(input.Position.X)
						end
					end)

					slider["36"].InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							dragging = true
							updateSlider(input.Position.X)
						end
					end)

					UIS.InputChanged:Connect(function(input)
						if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
							updateSlider(input.Position.X)
						end
					end)

					UIS.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							dragging = false
						end
					end)

					-- Set initial visual position to match starting sliderVal
					do
						local initPercent = (sliderVal - minVal) / (maxVal - minVal)
						slider["3c"].Position = UDim2.new(initPercent, 0, -1.33333, 0)
						slider["3e"].Text = tostring(sliderVal)
					end

					function slider:SetVal(val)
						local newVal = roundToIncrement(val)
						local percent = (newVal - minVal) / (maxVal - minVal)

						sliderVal = newVal
						slider["3c"].Position = UDim2.new(percent, 0, -1.33333, 0)
						slider["3e"].Text = tostring(newVal)
					end

					function slider:GetVal()
						return sliderVal
					end

