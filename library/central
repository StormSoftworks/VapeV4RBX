		--- RADAR LOGIC ---

		local radarBlips = {}

		-- Function to handle clean blip creation
		local function createBlip(targetPlayer)
			if targetPlayer == player then return end

			local blip = window["ae"]:Clone()
			blip.Name = targetPlayer.Name
			blip.Parent = window["a8"]
			radarBlips[targetPlayer] = blip
		end

		-- Track players joining/leaving
		Players.PlayerAdded:Connect(createBlip)
		Players.PlayerRemoving:Connect(function(targetPlayer)
			if radarBlips[targetPlayer] then
				radarBlips[targetPlayer]:Destroy()
				radarBlips[targetPlayer] = nil
			end
		end)

		-- Generate blips for players already in the server
		for _, p in ipairs(Players:GetPlayers()) do
			createBlip(p)
		end

		-- Update Loop
		RunService.RenderStepped:Connect(function()
			local localChar = player.Character
			local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")

			if not localHRP then
				-- If local player is dead/missing, hide all blips
				for _, blip in pairs(radarBlips) do
					blip.Visible = false
				end
				return
			end

			-- Get local player's position and camera/facing angle
			local localPos = localHRP.Position
			-- Using CFrame.LookVector on the XZ plane to account for character rotation
			local forwardVector = Vector3.new(localHRP.CFrame.LookVector.X, 0, localHRP.CFrame.LookVector.Z).Unit

			for targetPlayer, blip in pairs(radarBlips) do
				local targetChar = targetPlayer.Character
				local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

				if targetHRP then
					-- Calculate relative distance vectors
					local delta = targetHRP.Position - localPos
					local distance = Vector3.new(delta.X, 0, delta.Z).Magnitude

					if distance <= RADAR_RANGE then
						-- Convert world position relative to player's facing direction
						-- This rotates the radar so the top of the GUI is always 'Forward' for your character
						local relativeX = delta.X * forwardVector.Z - delta.Z * forwardVector.X
						local relativeY = delta.X * forwardVector.X + delta.Z * forwardVector.Z

						-- Translate relative position into UI scale (-0.5 to 0.5 offset range)
						local screenX = 0.5 + (relativeX / RADAR_RANGE) * 0.5
						local screenY = 0.5 + (relativeY / RADAR_RANGE) * 0.5

						blip.Position = UDim2.new(screenX, 0, screenY, 0)
						blip.Visible = true
					else
						blip.Visible = false -- Too far away
					end
				else
					blip.Visible = false -- Target player dead or hasn't spawned
				end
			end
		end)
		
		

